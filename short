<body>

<div class="video-wrap">
  <iframe
    src="https://drive.google.com/file/d/1xweLNNs6gDXuDDvmexHpQDfiUfDCxeFv/preview"
    allow="autoplay; fullscreen"
    allowfullscreen>
  </iframe>
</div>

<!-- ▼ ここ追加 -->
<div class="btn-wrap">
  <a href="https://drive.google.com/file/d/1xweLNNs6gDXuDDvmexHpQDfiUfDCxeFv/view" 
